@using TP4_Identity_Web.ViewModels.Home
@model AccueilVM

@{
    ViewData["Title"] = "Bienvenue en Terre du Milieu";
}
<br />
<br />
<div class="container-fluid px-0">
    <div id="carouselExampleSlidesOnly" class="carousel slide w-100" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/images/banner-gondor.svg" class="d-block w-100" alt="Image 1" />
            </div>
            <div class="carousel-item">
                <img src="~/images/banner-elfes.svg" class="d-block w-100" alt="Image 2" />
            </div>
            <div class="carousel-item">
                <img src="~/images/banner-hobbits.svg" class="d-block w-100" alt="Image 3" />
            </div>
        </div>
    </div>
</div>


<br />
<br />
<div class="container text-center">
    <div class="row justify-content-md-center">
        <div class="col col-lg-2">
            
        </div>
        <div class="col-md-auto">
            <div class="col-md-12">
                <div class="row">
                    <div class="col-sm-4 mb-3 mb-sm-0">
                        <div class="card mb-3">
                            <h3 class="card-header">Guerriers</h3>
                            <div class="card-body">
                                <h5 class="card-title">Guerriers du Gondor</h5>
                                <h6 class="card-subtitle text-muted">...</h6>
                            </div>
                            <svg xmlns="http://www.w3.org/2000/svg" class="d-block user-select-none" width="100%" height="200" aria-label="Placeholder: Image cap" focusable="false" role="img" preserveAspectRatio="xMidYMid slice" viewBox="0 0 318 180" style="font-size:1.125rem;text-anchor:middle">
                                <rect width="100%" height="100%" fill="#868e96"></rect>
                                <text x="50%" y="50%" fill="#dee2e6" dy=".3em">Image cap</text>
                            </svg>
                            <div class="card-body">
                                <p class="card-text">
                                    Défenseurs de Minas Tirith. Soldats, Capitaines et Intendants
                                    gardent la Cité Blanche contre les forces du Mordor.
                                </p>
                            </div>

                        </div>

                    </div>

                    <div class="col-sm-4 mb-3 mb-sm-0">
                        <div class="card mb-3">
                            <h3 class="card-header">Elfes</h3>
                            <div class="card-body">
                                <h5 class="card-title">Elfes</h5>
                                <h6 class="card-subtitle text-muted">...</h6>
                            </div>
                            <svg xmlns="http://www.w3.org/2000/svg" class="d-block user-select-none" width="100%" height="200" aria-label="Placeholder: Image cap" focusable="false" role="img" preserveAspectRatio="xMidYMid slice" viewBox="0 0 318 180" style="font-size:1.125rem;text-anchor:middle">
                                <rect width="100%" height="100%" fill="#868e96"></rect>
                                <text x="50%" y="50%" fill="#dee2e6" dy=".3em">Image cap</text>
                            </svg>
                            <div class="card-body">
                                <p class="card-text">
                                    Immortels et sages, venus de Lórien ou de la Forêt Noire.
                                    Gardiens des Archives d'Imladris et protecteurs des anciens savoirs.
                                </p>
                            </div>

                        </div>

                    </div>

                    <div class="col-sm-4 mb-3 mb-sm-0">
                        <div class="card mb-3">
                            <h3 class="card-header">Hobbits</h3>
                            <div class="card-body">
                                <h5 class="card-title">Hobbits de la Comté</h5>
                                <h6 class="card-subtitle text-muted">...</h6>
                            </div>
                            <svg xmlns="http://www.w3.org/2000/svg" class="d-block user-select-none" width="100%" height="200" aria-label="Placeholder: Image cap" focusable="false" role="img" preserveAspectRatio="xMidYMid slice" viewBox="0 0 318 180" style="font-size:1.125rem;text-anchor:middle">
                                <rect width="100%" height="100%" fill="#868e96"></rect>
                                <text x="50%" y="50%" fill="#dee2e6" dy=".3em">Image cap</text>
                            </svg>
                            <div class="card-body">
                                <p class="card-text">
                                    Paisibles habitants de Hobbiton, Cul-de-Sac, Lézeau et Bouc-de-l'Est.
                                    Jardiniers, Agriculteurs, Cuisiniers et Messagers.
                                </p>
                            </div>

                        </div>

                    </div>

                    
                    
                   
                </div>
            </div>
        </div>
</div>